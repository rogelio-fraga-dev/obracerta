# ─────────────────────────────────────────────────────────────
# Deploy/demo — copie para `.env.prod` na EC2 e preencha.
# NUNCA versione o `.env.prod` real.
# ─────────────────────────────────────────────────────────────

# ── Hosts públicos (sslip.io resolve o IP automaticamente) ───
# Troque 1-2-3-4 pelo IP público da EC2 com hífens. Ex.: IP 54.207.10.20 →
#   PUBLIC_HOST=app.54-207-10-20.sslip.io
#   FILES_HOST=files.54-207-10-20.sslip.io
PUBLIC_HOST=app.1-2-3-4.sslip.io
FILES_HOST=files.1-2-3-4.sslip.io
# URLs completas derivadas dos hosts acima (com https://). Mantenha em sincronia.
PUBLIC_URL=https://app.1-2-3-4.sslip.io
FILES_URL=https://files.1-2-3-4.sslip.io
# E-mail para o Let's Encrypt (avisos de expiração de certificado).
ACME_EMAIL=voce@exemplo.com

# ── Marca (desacoplada — assada no build do web) ─────────────
NEXT_PUBLIC_BRAND_NAME=ObraCerta
NEXT_PUBLIC_BRAND_DOMAIN=obracerta.com.br

# ── Banco (container PostGIS na própria EC2) ─────────────────
POSTGRES_USER=obracerta
# Gere uma senha forte: `openssl rand -hex 16`
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=obracerta

# ── Auth ─────────────────────────────────────────────────────
# Gere: `openssl rand -hex 32`
JWT_SECRET=TROQUE_POR_SEGREDO_FORTE_32_CHARS_MIN

# ── Storage S3 (MinIO) ───────────────────────────────────────
S3_BUCKET=obracerta
S3_ACCESS_KEY=obracerta
# Gere: `openssl rand -hex 16`
S3_SECRET_KEY=TROQUE_POR_SENHA_FORTE

# ── Webhooks billing (Asaas — fake/console no demo) ──────────
PAYMENT_WEBHOOK_SECRET=demo-webhook-secret-troque

# ── Onboarding (86400 = "1 dia" vira 1s; bom p/ demo) ────────
ONBOARDING_SPEEDUP=86400

# ── Seed (demo) — SENHAS FORTES numa demo pública! ───────────
# Sem isto, o seed cria admin@example.com com senha conhecida (docs/credenciais-local.txt).
# Gere: `openssl rand -base64 18`
SEED_ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE
SEED_USER_PASSWORD=TROQUE_POR_SENHA_FORTE
