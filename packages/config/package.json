{
  "name": "@obracerta/config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared ESLint, Prettier, TypeScript and Tailwind configuration for the monorepo.",
  "type": "module",
  "exports": {
    "./eslint/base": "./eslint/base.js",
    "./eslint/nest": "./eslint/nest.js",
    "./eslint/next": "./eslint/next.js",
    "./prettier": "./prettier/index.js",
    "./tailwind": "./tailwind/preset.js",
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/nestjs.json": "./tsconfig/nestjs.json",
    "./tsconfig/nextjs.json": "./tsconfig/nextjs.json",
    "./tsconfig/react-library.json": "./tsconfig/react-library.json"
  },
  "scripts": {
    "lint": "eslint .",
