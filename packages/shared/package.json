{
  "name": "@obracerta/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Tipos e schemas Zod compartilhados entre apps/web e apps/api (type-safety end-to-end).",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "peerDependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@obracerta/config": "workspace:*",
    "eslint": "^9.18.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9",
    "zod": "^3.24.1"
  }
}
