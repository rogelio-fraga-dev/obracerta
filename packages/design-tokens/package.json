{
  "name": "@obracerta/design-tokens",
  "version": "0.0.0",
  "private": true,
  "description": "Design tokens (paleta, tipografia, espaçamento) como TS + CSS custom properties.",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tokens.css": "./src/tokens.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src/tokens.css"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "@obracerta/config": "workspace:*",
    "eslint": "^10.6.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3"
  }
}
