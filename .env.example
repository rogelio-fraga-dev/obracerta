# ─────────────────────────────────────────────────────────────
# QuemFaz/ObraCerta — environment template (Fase 0)
# Copy to `.env` and fill values. NEVER commit the real `.env`.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# ── apps/api (NestJS) ────────────────────────────────────────
API_PORT=3333
# Comma-separated list of allowed CORS origins
API_CORS_ORIGINS=http://localhost:3000

# PostgreSQL 16 + PostGIS (matches infra/docker/docker-compose.yml)
DATABASE_URL=postgresql://obracerta:obracerta@localhost:5432/obracerta

# Redis (cache, sessions/OTP, BullMQ backend)
REDIS_URL=redis://localhost:6379

# ── apps/web (Next.js 15) ────────────────────────────────────
# Public base URL of the REST API consumed by the web app
NEXT_PUBLIC_API_URL=http://localhost:3333

# ── Brand (decoupled — see plan §1/§2.7) ─────────────────────
# Marca/domínio NUNCA hardcoded. Rename = trocar env, sem refatorar.
NEXT_PUBLIC_BRAND_NAME=ObraCerta
NEXT_PUBLIC_BRAND_DOMAIN=obracerta.com.br

# ── External providers (Fase 1+ — placeholders só p/ referência) ──
# ASAAS_API_KEY=
# WHATSAPP_CLOUD_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# SMS_PROVIDER_API_KEY=
