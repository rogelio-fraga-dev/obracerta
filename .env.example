# ─────────────────────────────────────────────────────────────
# QuemFaz/ObraCerta — environment template (Fase 0)
# Copy to `.env` and fill values. NEVER commit the real `.env`.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# ── apps/api (NestJS) ────────────────────────────────────────
API_PORT=3333
# Comma-separated list of allowed CORS origins
API_CORS_ORIGINS=http://localhost:3000

# PostgreSQL 16 + PostGIS (matches infra/docker/docker-compose.yml)
DATABASE_URL=postgresql://obracerta:obracerta@localhost:5432/obracerta

# Redis (cache, sessions/OTP, BullMQ backend)
REDIS_URL=redis://localhost:6379

# ── Auth (roadmap §6) ────────────────────────────────────────
# JWT_SECRET: mínimo 16 chars. Em produção, gere um segredo forte e guarde no
# secret manager — NUNCA versione o valor real.
JWT_SECRET=dev-only-insecure-secret-change-me-32chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# ── Object storage S3-compatível (roadmap §4.2) ─────────────
# MinIO local (infra/docker). Em produção, troque por Cloudflare R2 (mesma API S3).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=obracerta
S3_ACCESS_KEY=obracerta
S3_SECRET_KEY=obracerta123
S3_PUBLIC_URL=http://localhost:9000

# ── Onboarding (roadmap §5) ──────────────────────────────────
# Aceleração das mensagens progressivas: 1 = dias reais (D1/D3/D5/D7).
# Em dev, 86400 faz "1 dia" virar 1s para testar a fila rapidamente.
ONBOARDING_SPEEDUP=1

# ── apps/web (Next.js 15) ────────────────────────────────────
# Public base URL of the REST API consumed by the web app
NEXT_PUBLIC_API_URL=http://localhost:3333

# ── Brand (decoupled — see plan §1/§2.7) ─────────────────────
# Marca/domínio NUNCA hardcoded. Rename = trocar env, sem refatorar.
NEXT_PUBLIC_BRAND_NAME=ObraCerta
NEXT_PUBLIC_BRAND_DOMAIN=obracerta.com.br

# ── External providers (Fase 1+ — placeholders só p/ referência) ──
# ASAAS_API_KEY=
# WHATSAPP_CLOUD_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# SMS_PROVIDER_API_KEY=
